{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@app/product": ["libs/product/src/index.ts"],
      "@app/product/client": ["libs/product/src/client/index.ts"],
      "@app/order": ["libs/order/src/index.ts"],
      "@app/order/client": ["libs/order/src/client/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
